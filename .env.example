# -----------------------------------------------------------------------------
# Only Bitcoin - Environment Variables Template (.env.example)
# Copy this file to '.env' or '.env.local' and fill in the values.
# -----------------------------------------------------------------------------

# Next.js General Configuration
NEXT_PUBLIC_URL=https://only-btc.app
NEXT_PUBLIC_TITLE="Only Bitcoin"
NEXT_PUBLIC_APP_VERSION=v4.0.2

# Analytics & Ads
NEXT_PUBLIC_GA_TRACKING_ID=
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Domain Data URLs
NEXT_PUBLIC_MEME_IMAGE_URL=

# Donation & Links
NEXT_PUBLIC_DONATION_ADDRESS=
NEXT_PUBLIC_FEEDBACK_URL=https://x.com/a7w2en7z_

# Supabase (Required for quiz, rewards, and database actions)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Blink Wallet (Required for Lightning quiz rewards API)
BLINK_ACCESS_TOKEN=
